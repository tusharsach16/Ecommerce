# Database Configuration (Docker)
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=ecommerce

# Spring Datasource Configuration (Local/Docker)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/ecommerce
SPRING_DATASOURCE_USERNAME=your_postgres_user
SPRING_DATASOURCE_PASSWORD=your_secure_password

# Security Configuration
# Generate a random 256-bit key (at least 32 characters)
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars

# Frontend Configuration
VITE_API_BASE_URL=http://localhost:8080/api
